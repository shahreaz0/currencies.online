echo '🔧 Running pre-commit checks...'

run_checks() {
  echo '📝 Checking Biome formatting and linting...'
  pnpm exec biome check . || {
    echo '❌ Biome check failed. Run `pnpm run check` to fix formatting and linting issues.'
    exit 1
  }
  echo '✅ Biome check passed.'

  echo '🛠️ Checking TypeScript types...'
  pnpm run typecheck || {
    echo '❌ TypeScript type check failed. Review errors to fix type issues.'
    exit 1
  }
  echo '✅ TypeScript type check passed.'

  echo '🏗️ Building project...'
  pnpm run build || {
    echo '❌ Build failed. Review errors to resolve build issues.'
    exit 1
  }
  echo '✅ Build passed.'
}

# Execute checks
run_checks

echo '✅ All checks passed. Proceeding with commit.'